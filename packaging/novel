#!/bin/bash
# 小说阅读器全局命令（由 .pkg 安装到 /usr/local/bin/novel）。
#   novel            终端版（默认）
#   novel --gui      桌面图形界面
#   novel <参数>     透传给程序
set -euo pipefail

APP="/Applications/小说阅读器.app/Contents/MacOS/小说阅读器"

if [ ! -x "$APP" ]; then
  echo "未找到 小说阅读器.app，请先安装（双击 .pkg）。" >&2
  exit 1
fi

if [ "${1:-}" = "--gui" ] || [ "${1:-}" = "-g" ]; then
  shift
  exec "$APP" "$@"
elif [ "$#" -eq 0 ]; then
  exec "$APP" --tui
else
  exec "$APP" "$@"
fi
